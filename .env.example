# ── Supabase (PÚBLICAS — se inlinean en el bundle del cliente al build) ──
# En Vercel: texto plano, NO marcar como Sensitive (si se marcan, no se inlinean
# y el build truena al prerenderizar — lección del release anterior).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Analítica (opcional · consent-gated por el CookieBanner) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_CLARITY_ID=

# ── Sentry (opcional · observabilidad) ──
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Solo para subir source-maps en el build (opcional):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ── Server-only (opcional) ──
# v1 persiste el snapshot con el cliente de SESIÓN (anon + JWT), NO service-role.
# Solo defínela si algún flujo server la necesita.
SUPABASE_SERVICE_ROLE_KEY=
